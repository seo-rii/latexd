\ProvidesPackage{shim}[2024/01/01]
\def\shimmode{plain}
\DeclareOption{unicode}{\def\shimmode{unicode}}
\ProcessOptions\relax
\def\shimseed{shim-\shimmode}
\edef\shimfrozen{\shimseed}
\edef\shimdeferred{\unexpanded{\shimseed+\shimseed}}
{\def\shimseed{shim-local-\shimmode}\xdef\shimxdeferred{\unexpanded{\shimseed+\shimseed}}}
\def\shimseed{shimmutated-\shimmode}
