{
  "name": "@latexd/viewer-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "pnpm --filter @latexd/viewer-core build && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "pnpm --filter @latexd/viewer-core build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "pnpm check && pnpm test:runtime",
    "test:runtime": "pnpm --filter @latexd/viewer-core build && tsx --test test/latexd-client.test.ts && tsx --test test/viewer-host.test.ts",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:wasm": "LATEXD_VIEWER_BASE_PATH=/latexd VITE_LATEXD_BROWSER_ONLY=true pnpm build && playwright test --config playwright.wasm.config.ts"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@latexd/viewer-core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.2",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
